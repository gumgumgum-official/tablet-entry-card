VITE_SUPABASE_PROJECT_ID="ar--"
VITE_SUPABASE_PUBLISHABLE_KEY="ey--"
VITE_SUPABASE_URL="https://ar--"

# gum_server REST API base URL (예: https://gum-server.example.com)
VITE_GUM_SERVER_URL="http://localhost:3000"
VITE_GUM_SERVER_REQUEST_TIMEOUT_MS=5000
VITE_GUM_SERVER_POLL_INTERVAL_MS=1500
VITE_GUM_SERVER_POLL_MAX_WAIT_MS=60000

# 아래 VITE_* 는 빌드 시 번들에 들어갑니다. Vercel에서 수정 후 반드시 Redeploy 하세요.

# 프로덕션에서 펜 외 touch 입력 허용 (일부 iPad/Safari에서 펜슬이 touch로 들어올 때)
# VITE_ALLOW_TOUCH_AS_PEN=true

# 프로덕션에서 마우스로도 필기 (데스크톱 테스트 등)
# VITE_ALLOW_MOUSE=true

# 프로덕션에서 pointerType 구분 없이 전부 허용 (pen/touch/mouse 이외 타입 대비·키오스크)
# VITE_ALLOW_ALL_POINTERS=true

# 거절된 pointerdown 시 Safari 원격 디버그 등에서 원인 확인용
# VITE_DEBUG_POINTER=true
